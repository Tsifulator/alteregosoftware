# ─────────────────────────────────────────────────────────────────────────────
# ALTER EGO candidate-intake app — copy to .env and fill in.
# Workable creds are the SAME ones used by ../alteregohr — copy them from there.
# ─────────────────────────────────────────────────────────────────────────────

# --- Workable (required to actually push candidates) ---
WORKABLE_SUBDOMAIN=
WORKABLE_API_TOKEN=
# Shortcode of the job new walk-ins attach to (from the job URL, or GET /spi/v3/jobs).
WORKABLE_INTAKE_JOB=
# New candidates land in the "sourced" (true) or "applied" (false) stage.
WORKABLE_SOURCED=true

# Email is required by Workable; walk-ins without one get a placeholder on this
# (non-deliverable) domain and a "no-email" tag.
PLACEHOLDER_EMAIL_DOMAIN=candidates.alterego.invalid

# --- App behaviour ---
KIOSK_MODE=true             # no login; thank-you screen auto-resets for the next person
KIOSK_RESET_SECONDS=8
ORG_NAME=ALTER EGO
DEFAULT_PHONE_CC=+30        # prepended to phones entered without a country code
ADMIN_PIN=                  # set a PIN to enable the /admin oversight page (empty = disabled)
SESSION_SECRET=change-me-in-prod

# If true, NEVER call Workable — write the payload to logs/ instead (for testing).
DRY_RUN=false

# --- Optional: translate free-text answers to Greek for HR (best-effort) ---
TRANSLATE_FREETEXT=true
LLM_BACKEND=auto            # auto -> local Ollama, else Groq, else Gemini, else Claude
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Persistence (set to a mounted volume path on Railway so data survives) ---
# SUBMISSIONS_PATH=/data/submissions.json
# QUEUE_PATH=/data/queue.json
